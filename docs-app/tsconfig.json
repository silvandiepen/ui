{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@sil/ui": ["../src/index.ts"],
      "@ui-lib/*": ["../src/*"],
      "@ui-docs/*": ["./src/*"],
      "@/*": ["../src/*"],
      "@/components/ui/*": ["../src/components/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "../src/**/*.ts",
    "../src/**/*.vue"
  ]
}
